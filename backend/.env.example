# ── Local development ────────────────────────────────────────────
PORT=4000
DATABASE_URL=postgresql://user:password@localhost:5432/hexcore_db
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# ── Railway production (set these in Railway → Service → Variables) ─
# DATABASE_URL   → injected automatically when you link a Railway PostgreSQL service
# PORT           → injected automatically by Railway (do NOT override)
# NODE_ENV       = production
# JWT_SECRET     = <64-char random string, e.g. openssl rand -hex 32>
# JWT_EXPIRES_IN = 7d
# FRONTEND_URL   = https://<your-project>.vercel.app
